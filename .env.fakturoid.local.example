# Copy this file to `.env.fakturoid.local`, fill in real values, and source it in fish.

set -gx FAKTUROID_CLIENT_ID 'replace-me'
set -gx FAKTUROID_CLIENT_SECRET 'replace-me'
set -gx FAKTUROID_USER_AGENT 'TestCompany (https://faktubot.thinkhome.org)'

# Optional for client-credentials live tests
set -gx FAKTUROID_SLUG 'thinkhome'

# Optional for OAuth auth-code live tests
set -gx FAKTUROID_REDIRECT_URI 'https://faktubot.thinkhome.org/auth/redirect'
set -gx FAKTUROID_OAUTH_CALLBACK_URI 'https://faktubot.thinkhome.org/auth/redirect?code=replace-me&state=replace-me'
