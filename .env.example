# Copy this file to `.env.fakturoid.local`, fill in real values, and source it.
# This file is compatible with bash, zsh, and fish (using 'source').

export FAKTUROID_CLIENT_ID='replace-me'
export FAKTUROID_CLIENT_SECRET='replace-me'
export FAKTUROID_USER_AGENT='TestCompany (https://faktubot.thinkhome.org)'
export FAKTUROID_PRESERVE_LIVE_FIXTURES='false'
export FAKTUROID_RUN_CLEANUP='false'

# Optional for client-credentials live tests
export FAKTUROID_SLUG='testcompany1'

# Optional for OAuth auth-code live tests
export FAKTUROID_REDIRECT_URI='https://faktubot.thinkhome.org/auth/redirect'
export FAKTUROID_OAUTH_CLIENT_ID='replace-me'
export FAKTUROID_OAUTH_CLIENT_SECRET='replace-me'
export FAKTUROID_OAUTH_REDIRECT_URI='https://faktubot.thinkhome.org/auth/redirect'
export FAKTUROID_OAUTH_CALLBACK_URI='https://faktubot.thinkhome.org/auth/redirect?code=replace-me&state=replace-me'
